//@version=6
indicator("MS iFVG Framework v0.2", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

//------------------------------------------------------------------------------
// Inputs
//------------------------------------------------------------------------------
groupGeneral = "General"
groupDisplay = "Display"
groupLiquidity = "Liquidity"
groupSessions = "Sessions"
groupFvg = "FVG"

displayMode = input.string("Clean", "Display Mode", options=["Clean", "Study"], group=groupGeneral)
swingLength = input.int(5, "Swing Length", minval=1, group=groupGeneral)

bslColor = input.color(color.new(color.lime, 0), "BSL Marker Color", group=groupDisplay)
sslColor = input.color(color.new(color.red, 0), "SSL Marker Color", group=groupDisplay)
markerTextColor = input.color(color.white, "Marker Text Color", group=groupDisplay)
maxSweepChartTimeframe = input.timeframe("15", "Show Sweeps Through Chart TF", group=groupDisplay)

showLiquiditySweeps = input.bool(true, "Show Liquidity Sweeps", group=groupLiquidity)

showAsiaSession = input.bool(false, "Show Asia High/Low", group=groupSessions)
asiaSession = input.session("1800-0000", "Asia Session (NY Time)", group=groupSessions)
asiaColor = input.color(color.new(color.teal, 0), "Asia Line Color", group=groupSessions)

showLondonSession = input.bool(false, "Show London High/Low", group=groupSessions)
londonSession = input.session("0200-0500", "London Session (NY Time)", group=groupSessions)
londonColor = input.color(color.new(color.orange, 0), "London Line Color", group=groupSessions)

showFvgs = input.bool(true, "Show FVGs", group=groupFvg)
showChartFvgs = input.bool(true, "Show Chart TF FVGs", group=groupFvg)
fvgDetection = input.string("Wick-based", "FVG Detection", options=["Wick-based", "Body-based"], group=groupFvg)
extendFvgs = input.bool(true, "Extend FVGs", group=groupFvg)
hideFilledFvgs = input.bool(true, "Hide Filled FVGs", group=groupFvg)
fvgRemovalMode = input.string("Touch", "Remove FVG On", options=["Touch", "Full Fill"], group=groupFvg)
minFvgTicks = input.int(4, "Minimum FVG Size (Ticks)", minval=1, group=groupFvg)
showFvgBorder = input.bool(false, "Show FVG Border", group=groupFvg)
showFvgMidline = input.bool(true, "Show FVG Middle Line", group=groupFvg)
showFvgTimeframe = input.bool(true, "Show FVG Timeframe Label", group=groupFvg)
showMtfFvgs = input.bool(true, "Show Selected TF FVGs", group=groupFvg)
showMtfFvg1 = input.bool(false, "Show 5M FVGs", group=groupFvg)
mtfFvgTimeframe1 = input.timeframe("5", "FVG Timeframe 1", group=groupFvg)
showMtfFvg2 = input.bool(true, "Show 15M FVGs", group=groupFvg)
mtfFvgTimeframe2 = input.timeframe("15", "FVG Timeframe 2", group=groupFvg)
showMtfFvg3 = input.bool(false, "Show 30M FVGs", group=groupFvg)
mtfFvgTimeframe3 = input.timeframe("30", "FVG Timeframe 3", group=groupFvg)
showMtfFvg4 = input.bool(false, "Show 1H FVGs", group=groupFvg)
mtfFvgTimeframe4 = input.timeframe("60", "FVG Timeframe 4", group=groupFvg)
showMtfFvg5 = input.bool(false, "Show 4H FVGs", group=groupFvg)
mtfFvgTimeframe5 = input.timeframe("240", "FVG Timeframe 5", group=groupFvg)
maxMtfFvgs = input.int(20, "Maximum Active Selected TF FVGs", minval=1, maxval=100, group=groupFvg)
bullishFvgColor = input.color(color.new(color.rgb(38, 166, 154), 86), "Bullish FVG Color", group=groupFvg)
bearishFvgColor = input.color(color.new(color.rgb(239, 83, 80), 86), "Bearish FVG Color", group=groupFvg)
fvgMidlineColor = input.color(color.new(color.black, 55), "FVG Middle Line Color", group=groupFvg)
fvgTextColor = input.color(color.new(color.black, 0), "FVG Label Text Color", group=groupFvg)

//------------------------------------------------------------------------------
// Liquidity engine
//------------------------------------------------------------------------------
pivotHigh = ta.pivothigh(high, swingLength, swingLength)
pivotLow = ta.pivotlow(low, swingLength, swingLength)

var float lastSwingHigh = na
var float lastSwingLow = na
var bool lastSwingHighSwept = false
var bool lastSwingLowSwept = false
var label latestBslLabel = na
var label latestSslLabel = na

if not na(pivotHigh)
    lastSwingHigh := pivotHigh
    lastSwingHighSwept := false

if not na(pivotLow)
    lastSwingLow := pivotLow
    lastSwingLowSwept := false

isCleanMode = displayMode == "Clean"
showSweepsOnChartTimeframe = timeframe.in_seconds(timeframe.period) <= timeframe.in_seconds(maxSweepChartTimeframe)
bslSweep = showSweepsOnChartTimeframe and showLiquiditySweeps and not na(lastSwingHigh) and not lastSwingHighSwept and high > lastSwingHigh
sslSweep = showSweepsOnChartTimeframe and showLiquiditySweeps and not na(lastSwingLow) and not lastSwingLowSwept and low < lastSwingLow

if bslSweep
    lastSwingHighSwept := true
    if isCleanMode and not na(latestBslLabel)
        label.delete(latestBslLabel)
    latestBslLabel := label.new(bar_index, high, "BSL", style=label.style_label_down, color=bslColor, textcolor=markerTextColor, size=size.small)

if sslSweep
    lastSwingLowSwept := true
    if isCleanMode and not na(latestSslLabel)
        label.delete(latestSslLabel)
    latestSslLabel := label.new(bar_index, low, "SSL", style=label.style_label_up, color=sslColor, textcolor=markerTextColor, size=size.small)

//------------------------------------------------------------------------------
// FVG detection and display
//------------------------------------------------------------------------------
oldBodyHigh = math.max(open[2], close[2])
oldBodyLow = math.min(open[2], close[2])
currentBodyHigh = math.max(open, close)
currentBodyLow = math.min(open, close)

oldRangeHigh = fvgDetection == "Body-based" ? oldBodyHigh : high[2]
oldRangeLow = fvgDetection == "Body-based" ? oldBodyLow : low[2]
currentRangeHigh = fvgDetection == "Body-based" ? currentBodyHigh : high
currentRangeLow = fvgDetection == "Body-based" ? currentBodyLow : low
minimumFvgSize = minFvgTicks * syminfo.mintick

bullishFvgTop = currentRangeLow
bullishFvgBottom = oldRangeHigh
bearishFvgTop = oldRangeLow
bearishFvgBottom = currentRangeHigh

formatTimeframeLabel(string tf) =>
    timeframeSeconds = timeframe.in_seconds(tf)
    timeframeSeconds < 60 ? str.tostring(timeframeSeconds, "#") + "S" : timeframeSeconds < 3600 ? str.tostring(timeframeSeconds / 60, "#") + "M" : timeframeSeconds < 86400 ? str.tostring(timeframeSeconds / 3600, "#") + "H" : tf

detectFvg() =>
    oldBodyHighLocal = math.max(open[2], close[2])
    oldBodyLowLocal = math.min(open[2], close[2])
    currentBodyHighLocal = math.max(open, close)
    currentBodyLowLocal = math.min(open, close)
    oldRangeHighLocal = fvgDetection == "Body-based" ? oldBodyHighLocal : high[2]
    oldRangeLowLocal = fvgDetection == "Body-based" ? oldBodyLowLocal : low[2]
    currentRangeHighLocal = fvgDetection == "Body-based" ? currentBodyHighLocal : high
    currentRangeLowLocal = fvgDetection == "Body-based" ? currentBodyLowLocal : low
    bullishTopLocal = currentRangeLowLocal
    bullishBottomLocal = oldRangeHighLocal
    bearishTopLocal = oldRangeLowLocal
    bearishBottomLocal = currentRangeHighLocal
    bullishLocal = bullishTopLocal > bullishBottomLocal and bullishTopLocal - bullishBottomLocal >= minimumFvgSize
    bearishLocal = bearishTopLocal > bearishBottomLocal and bearishTopLocal - bearishBottomLocal >= minimumFvgSize
    [bullishLocal, bearishLocal, bullishTopLocal, bullishBottomLocal, bearishTopLocal, bearishBottomLocal, time[2], time]

bullishFvg = showFvgs and showChartFvgs and bullishFvgTop > bullishFvgBottom and bullishFvgTop - bullishFvgBottom >= minimumFvgSize
bearishFvg = showFvgs and showChartFvgs and bearishFvgTop > bearishFvgBottom and bearishFvgTop - bearishFvgBottom >= minimumFvgSize
fvgTimeframeText = formatTimeframeLabel(timeframe.period)
fvgBoxText = showFvgTimeframe ? fvgTimeframeText : ""
mtfFvgText1 = showFvgTimeframe ? formatTimeframeLabel(mtfFvgTimeframe1) : ""
mtfFvgText2 = showFvgTimeframe ? formatTimeframeLabel(mtfFvgTimeframe2) : ""
mtfFvgText3 = showFvgTimeframe ? formatTimeframeLabel(mtfFvgTimeframe3) : ""
mtfFvgText4 = showFvgTimeframe ? formatTimeframeLabel(mtfFvgTimeframe4) : ""
mtfFvgText5 = showFvgTimeframe ? formatTimeframeLabel(mtfFvgTimeframe5) : ""
fvgBorderColor = showFvgBorder ? color.new(color.gray, 35) : color.new(color.gray, 100)

var box latestBullishFvgBox = na
var box latestBearishFvgBox = na
var line latestBullishFvgMidline = na
var line latestBearishFvgMidline = na
var array<box> bullishFvgBoxes = array.new<box>()
var array<box> bearishFvgBoxes = array.new<box>()
var array<float> bullishFvgBottoms = array.new<float>()
var array<float> bearishFvgTops = array.new<float>()
var array<line> bullishFvgMidlines = array.new<line>()
var array<line> bearishFvgMidlines = array.new<line>()
removeFvgOnTouch = fvgRemovalMode == "Touch"

if bullishFvg
    if isCleanMode and not na(latestBullishFvgBox)
        box.delete(latestBullishFvgBox)
    if isCleanMode and not na(latestBullishFvgMidline)
        line.delete(latestBullishFvgMidline)
    if isCleanMode
        array.clear(bullishFvgBoxes)
        array.clear(bullishFvgBottoms)
        array.clear(bullishFvgMidlines)
    latestBullishFvgBox := box.new(bar_index - 2, bullishFvgTop, bar_index, bullishFvgBottom, border_color=fvgBorderColor, bgcolor=bullishFvgColor, text=fvgBoxText, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    latestBullishFvgMidline := showFvgMidline ? line.new(bar_index - 2, (bullishFvgTop + bullishFvgBottom) / 2, bar_index, (bullishFvgTop + bullishFvgBottom) / 2, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(bullishFvgBoxes, latestBullishFvgBox)
    array.push(bullishFvgBottoms, bullishFvgBottom)
    array.push(bullishFvgMidlines, latestBullishFvgMidline)

if bearishFvg
    if isCleanMode and not na(latestBearishFvgBox)
        box.delete(latestBearishFvgBox)
    if isCleanMode and not na(latestBearishFvgMidline)
        line.delete(latestBearishFvgMidline)
    if isCleanMode
        array.clear(bearishFvgBoxes)
        array.clear(bearishFvgTops)
        array.clear(bearishFvgMidlines)
    latestBearishFvgBox := box.new(bar_index - 2, bearishFvgTop, bar_index, bearishFvgBottom, border_color=fvgBorderColor, bgcolor=bearishFvgColor, text=fvgBoxText, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    latestBearishFvgMidline := showFvgMidline ? line.new(bar_index - 2, (bearishFvgTop + bearishFvgBottom) / 2, bar_index, (bearishFvgTop + bearishFvgBottom) / 2, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(bearishFvgBoxes, latestBearishFvgBox)
    array.push(bearishFvgTops, bearishFvgTop)
    array.push(bearishFvgMidlines, latestBearishFvgMidline)

if not showFvgs or not showChartFvgs
    bullishCount = array.size(bullishFvgBoxes)
    if bullishCount > 0
        for step = 0 to bullishCount - 1
            i = bullishCount - 1 - step
            box.delete(array.get(bullishFvgBoxes, i))
            bullishMidline = array.get(bullishFvgMidlines, i)
            if not na(bullishMidline)
                line.delete(bullishMidline)
            array.remove(bullishFvgBoxes, i)
            array.remove(bullishFvgBottoms, i)
            array.remove(bullishFvgMidlines, i)

    bearishCount = array.size(bearishFvgBoxes)
    if bearishCount > 0
        for step = 0 to bearishCount - 1
            i = bearishCount - 1 - step
            box.delete(array.get(bearishFvgBoxes, i))
            bearishMidline = array.get(bearishFvgMidlines, i)
            if not na(bearishMidline)
                line.delete(bearishMidline)
            array.remove(bearishFvgBoxes, i)
            array.remove(bearishFvgTops, i)
            array.remove(bearishFvgMidlines, i)

    latestBullishFvgBox := na
    latestBearishFvgBox := na
    latestBullishFvgMidline := na
    latestBearishFvgMidline := na

if showFvgs and showChartFvgs
    bullishCount = array.size(bullishFvgBoxes)
    if bullishCount > 0
        for step = 0 to bullishCount - 1
            i = bullishCount - 1 - step
            bullishBox = array.get(bullishFvgBoxes, i)
            bullishBottom = array.get(bullishFvgBottoms, i)
            bullishMidline = array.get(bullishFvgMidlines, i)
            bullishTop = box.get_top(bullishBox)
            bullishFilled = removeFvgOnTouch ? low <= bullishTop : low <= bullishBottom
            if hideFilledFvgs and bullishFilled
                box.delete(bullishBox)
                if not na(bullishMidline)
                    line.delete(bullishMidline)
                array.remove(bullishFvgBoxes, i)
                array.remove(bullishFvgBottoms, i)
                array.remove(bullishFvgMidlines, i)
                if isCleanMode
                    latestBullishFvgBox := na
                    latestBullishFvgMidline := na
            else
                box.set_text(bullishBox, fvgBoxText)
                box.set_border_color(bullishBox, fvgBorderColor)
                if extendFvgs
                    box.set_right(bullishBox, bar_index)
                if not na(bullishMidline)
                    if showFvgMidline
                        if extendFvgs
                            line.set_x2(bullishMidline, bar_index)
                    else
                        line.delete(bullishMidline)
                        array.set(bullishFvgMidlines, i, na)

    bearishCount = array.size(bearishFvgBoxes)
    if bearishCount > 0
        for step = 0 to bearishCount - 1
            i = bearishCount - 1 - step
            bearishBox = array.get(bearishFvgBoxes, i)
            bearishTop = array.get(bearishFvgTops, i)
            bearishMidline = array.get(bearishFvgMidlines, i)
            bearishBottom = box.get_bottom(bearishBox)
            bearishFilled = removeFvgOnTouch ? high >= bearishBottom : high >= bearishTop
            if hideFilledFvgs and bearishFilled
                box.delete(bearishBox)
                if not na(bearishMidline)
                    line.delete(bearishMidline)
                array.remove(bearishFvgBoxes, i)
                array.remove(bearishFvgTops, i)
                array.remove(bearishFvgMidlines, i)
                if isCleanMode
                    latestBearishFvgBox := na
                    latestBearishFvgMidline := na
            else
                box.set_text(bearishBox, fvgBoxText)
                box.set_border_color(bearishBox, fvgBorderColor)
                if extendFvgs
                    box.set_right(bearishBox, bar_index)
                if not na(bearishMidline)
                    if showFvgMidline
                        if extendFvgs
                            line.set_x2(bearishMidline, bar_index)
                    else
                        line.delete(bearishMidline)
                        array.set(bearishFvgMidlines, i, na)

//------------------------------------------------------------------------------
// Selected timeframe FVG display
//------------------------------------------------------------------------------
[mtfBullishFvg1, mtfBearishFvg1, mtfBullishFvgTop1, mtfBullishFvgBottom1, mtfBearishFvgTop1, mtfBearishFvgBottom1, mtfFvgStartTime1, mtfFvgEventTime1] = request.security(syminfo.tickerid, mtfFvgTimeframe1, detectFvg(), barmerge.gaps_off, barmerge.lookahead_off)
[mtfBullishFvg2, mtfBearishFvg2, mtfBullishFvgTop2, mtfBullishFvgBottom2, mtfBearishFvgTop2, mtfBearishFvgBottom2, mtfFvgStartTime2, mtfFvgEventTime2] = request.security(syminfo.tickerid, mtfFvgTimeframe2, detectFvg(), barmerge.gaps_off, barmerge.lookahead_off)
[mtfBullishFvg3, mtfBearishFvg3, mtfBullishFvgTop3, mtfBullishFvgBottom3, mtfBearishFvgTop3, mtfBearishFvgBottom3, mtfFvgStartTime3, mtfFvgEventTime3] = request.security(syminfo.tickerid, mtfFvgTimeframe3, detectFvg(), barmerge.gaps_off, barmerge.lookahead_off)
[mtfBullishFvg4, mtfBearishFvg4, mtfBullishFvgTop4, mtfBullishFvgBottom4, mtfBearishFvgTop4, mtfBearishFvgBottom4, mtfFvgStartTime4, mtfFvgEventTime4] = request.security(syminfo.tickerid, mtfFvgTimeframe4, detectFvg(), barmerge.gaps_off, barmerge.lookahead_off)
[mtfBullishFvg5, mtfBearishFvg5, mtfBullishFvgTop5, mtfBullishFvgBottom5, mtfBearishFvgTop5, mtfBearishFvgBottom5, mtfFvgStartTime5, mtfFvgEventTime5] = request.security(syminfo.tickerid, mtfFvgTimeframe5, detectFvg(), barmerge.gaps_off, barmerge.lookahead_off)

var int lastMtfBullishFvgTime1 = na
var int lastMtfBearishFvgTime1 = na
var int lastMtfBullishFvgTime2 = na
var int lastMtfBearishFvgTime2 = na
var int lastMtfBullishFvgTime3 = na
var int lastMtfBearishFvgTime3 = na
var int lastMtfBullishFvgTime4 = na
var int lastMtfBearishFvgTime4 = na
var int lastMtfBullishFvgTime5 = na
var int lastMtfBearishFvgTime5 = na
var array<box> mtfFvgBoxes = array.new<box>()
var array<line> mtfFvgMidlines = array.new<line>()
var array<float> mtfFvgFillLevels = array.new<float>()
var array<bool> mtfFvgBullishFlags = array.new<bool>()

showSelectedTfFvgLayer = showFvgs and showMtfFvgs

if showSelectedTfFvgLayer and showMtfFvg1 and mtfBullishFvg1 and not na(mtfFvgEventTime1) and (na(lastMtfBullishFvgTime1) or mtfFvgEventTime1 != lastMtfBullishFvgTime1)
    lastMtfBullishFvgTime1 := mtfFvgEventTime1
    mtfBox = box.new(mtfFvgStartTime1, mtfBullishFvgTop1, time, mtfBullishFvgBottom1, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bullishFvgColor, text=mtfFvgText1, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime1, (mtfBullishFvgTop1 + mtfBullishFvgBottom1) / 2, time, (mtfBullishFvgTop1 + mtfBullishFvgBottom1) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBullishFvgBottom1)
    array.push(mtfFvgBullishFlags, true)

if showSelectedTfFvgLayer and showMtfFvg1 and mtfBearishFvg1 and not na(mtfFvgEventTime1) and (na(lastMtfBearishFvgTime1) or mtfFvgEventTime1 != lastMtfBearishFvgTime1)
    lastMtfBearishFvgTime1 := mtfFvgEventTime1
    mtfBox = box.new(mtfFvgStartTime1, mtfBearishFvgTop1, time, mtfBearishFvgBottom1, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bearishFvgColor, text=mtfFvgText1, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime1, (mtfBearishFvgTop1 + mtfBearishFvgBottom1) / 2, time, (mtfBearishFvgTop1 + mtfBearishFvgBottom1) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBearishFvgTop1)
    array.push(mtfFvgBullishFlags, false)

if showSelectedTfFvgLayer and showMtfFvg2 and mtfBullishFvg2 and not na(mtfFvgEventTime2) and (na(lastMtfBullishFvgTime2) or mtfFvgEventTime2 != lastMtfBullishFvgTime2)
    lastMtfBullishFvgTime2 := mtfFvgEventTime2
    mtfBox = box.new(mtfFvgStartTime2, mtfBullishFvgTop2, time, mtfBullishFvgBottom2, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bullishFvgColor, text=mtfFvgText2, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime2, (mtfBullishFvgTop2 + mtfBullishFvgBottom2) / 2, time, (mtfBullishFvgTop2 + mtfBullishFvgBottom2) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBullishFvgBottom2)
    array.push(mtfFvgBullishFlags, true)

if showSelectedTfFvgLayer and showMtfFvg2 and mtfBearishFvg2 and not na(mtfFvgEventTime2) and (na(lastMtfBearishFvgTime2) or mtfFvgEventTime2 != lastMtfBearishFvgTime2)
    lastMtfBearishFvgTime2 := mtfFvgEventTime2
    mtfBox = box.new(mtfFvgStartTime2, mtfBearishFvgTop2, time, mtfBearishFvgBottom2, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bearishFvgColor, text=mtfFvgText2, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime2, (mtfBearishFvgTop2 + mtfBearishFvgBottom2) / 2, time, (mtfBearishFvgTop2 + mtfBearishFvgBottom2) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBearishFvgTop2)
    array.push(mtfFvgBullishFlags, false)

if showSelectedTfFvgLayer and showMtfFvg3 and mtfBullishFvg3 and not na(mtfFvgEventTime3) and (na(lastMtfBullishFvgTime3) or mtfFvgEventTime3 != lastMtfBullishFvgTime3)
    lastMtfBullishFvgTime3 := mtfFvgEventTime3
    mtfBox = box.new(mtfFvgStartTime3, mtfBullishFvgTop3, time, mtfBullishFvgBottom3, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bullishFvgColor, text=mtfFvgText3, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime3, (mtfBullishFvgTop3 + mtfBullishFvgBottom3) / 2, time, (mtfBullishFvgTop3 + mtfBullishFvgBottom3) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBullishFvgBottom3)
    array.push(mtfFvgBullishFlags, true)

if showSelectedTfFvgLayer and showMtfFvg3 and mtfBearishFvg3 and not na(mtfFvgEventTime3) and (na(lastMtfBearishFvgTime3) or mtfFvgEventTime3 != lastMtfBearishFvgTime3)
    lastMtfBearishFvgTime3 := mtfFvgEventTime3
    mtfBox = box.new(mtfFvgStartTime3, mtfBearishFvgTop3, time, mtfBearishFvgBottom3, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bearishFvgColor, text=mtfFvgText3, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime3, (mtfBearishFvgTop3 + mtfBearishFvgBottom3) / 2, time, (mtfBearishFvgTop3 + mtfBearishFvgBottom3) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBearishFvgTop3)
    array.push(mtfFvgBullishFlags, false)

if showSelectedTfFvgLayer and showMtfFvg4 and mtfBullishFvg4 and not na(mtfFvgEventTime4) and (na(lastMtfBullishFvgTime4) or mtfFvgEventTime4 != lastMtfBullishFvgTime4)
    lastMtfBullishFvgTime4 := mtfFvgEventTime4
    mtfBox = box.new(mtfFvgStartTime4, mtfBullishFvgTop4, time, mtfBullishFvgBottom4, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bullishFvgColor, text=mtfFvgText4, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime4, (mtfBullishFvgTop4 + mtfBullishFvgBottom4) / 2, time, (mtfBullishFvgTop4 + mtfBullishFvgBottom4) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBullishFvgBottom4)
    array.push(mtfFvgBullishFlags, true)

if showSelectedTfFvgLayer and showMtfFvg4 and mtfBearishFvg4 and not na(mtfFvgEventTime4) and (na(lastMtfBearishFvgTime4) or mtfFvgEventTime4 != lastMtfBearishFvgTime4)
    lastMtfBearishFvgTime4 := mtfFvgEventTime4
    mtfBox = box.new(mtfFvgStartTime4, mtfBearishFvgTop4, time, mtfBearishFvgBottom4, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bearishFvgColor, text=mtfFvgText4, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime4, (mtfBearishFvgTop4 + mtfBearishFvgBottom4) / 2, time, (mtfBearishFvgTop4 + mtfBearishFvgBottom4) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBearishFvgTop4)
    array.push(mtfFvgBullishFlags, false)

if showSelectedTfFvgLayer and showMtfFvg5 and mtfBullishFvg5 and not na(mtfFvgEventTime5) and (na(lastMtfBullishFvgTime5) or mtfFvgEventTime5 != lastMtfBullishFvgTime5)
    lastMtfBullishFvgTime5 := mtfFvgEventTime5
    mtfBox = box.new(mtfFvgStartTime5, mtfBullishFvgTop5, time, mtfBullishFvgBottom5, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bullishFvgColor, text=mtfFvgText5, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime5, (mtfBullishFvgTop5 + mtfBullishFvgBottom5) / 2, time, (mtfBullishFvgTop5 + mtfBullishFvgBottom5) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBullishFvgBottom5)
    array.push(mtfFvgBullishFlags, true)

if showSelectedTfFvgLayer and showMtfFvg5 and mtfBearishFvg5 and not na(mtfFvgEventTime5) and (na(lastMtfBearishFvgTime5) or mtfFvgEventTime5 != lastMtfBearishFvgTime5)
    lastMtfBearishFvgTime5 := mtfFvgEventTime5
    mtfBox = box.new(mtfFvgStartTime5, mtfBearishFvgTop5, time, mtfBearishFvgBottom5, xloc=xloc.bar_time, border_color=fvgBorderColor, bgcolor=bearishFvgColor, text=mtfFvgText5, text_color=fvgTextColor, text_size=size.small, text_halign=text.align_center, text_valign=text.align_center)
    mtfLine = showFvgMidline ? line.new(mtfFvgStartTime5, (mtfBearishFvgTop5 + mtfBearishFvgBottom5) / 2, time, (mtfBearishFvgTop5 + mtfBearishFvgBottom5) / 2, xloc=xloc.bar_time, color=fvgMidlineColor, style=line.style_dashed, width=1) : na
    array.push(mtfFvgBoxes, mtfBox)
    array.push(mtfFvgMidlines, mtfLine)
    array.push(mtfFvgFillLevels, mtfBearishFvgTop5)
    array.push(mtfFvgBullishFlags, false)

while array.size(mtfFvgBoxes) > maxMtfFvgs
    oldMtfBox = array.shift(mtfFvgBoxes)
    oldMtfLine = array.shift(mtfFvgMidlines)
    array.shift(mtfFvgFillLevels)
    array.shift(mtfFvgBullishFlags)
    box.delete(oldMtfBox)
    if not na(oldMtfLine)
        line.delete(oldMtfLine)

if not showSelectedTfFvgLayer
    mtfCount = array.size(mtfFvgBoxes)
    if mtfCount > 0
        for step = 0 to mtfCount - 1
            i = mtfCount - 1 - step
            mtfStoredBox = array.get(mtfFvgBoxes, i)
            mtfStoredLine = array.get(mtfFvgMidlines, i)
            box.delete(mtfStoredBox)
            if not na(mtfStoredLine)
                line.delete(mtfStoredLine)
            array.remove(mtfFvgBoxes, i)
            array.remove(mtfFvgMidlines, i)
            array.remove(mtfFvgFillLevels, i)
            array.remove(mtfFvgBullishFlags, i)

if showSelectedTfFvgLayer
    mtfCount = array.size(mtfFvgBoxes)
    if mtfCount > 0
        for step = 0 to mtfCount - 1
            i = mtfCount - 1 - step
            mtfStoredBox = array.get(mtfFvgBoxes, i)
            mtfStoredLine = array.get(mtfFvgMidlines, i)
            mtfFillLevel = array.get(mtfFvgFillLevels, i)
            mtfIsBullish = array.get(mtfFvgBullishFlags, i)
            mtfTouchLevel = mtfIsBullish ? box.get_top(mtfStoredBox) : box.get_bottom(mtfStoredBox)
            mtfFilled = mtfIsBullish ? (removeFvgOnTouch ? low <= mtfTouchLevel : low <= mtfFillLevel) : (removeFvgOnTouch ? high >= mtfTouchLevel : high >= mtfFillLevel)
            if hideFilledFvgs and mtfFilled
                box.delete(mtfStoredBox)
                if not na(mtfStoredLine)
                    line.delete(mtfStoredLine)
                array.remove(mtfFvgBoxes, i)
                array.remove(mtfFvgMidlines, i)
                array.remove(mtfFvgFillLevels, i)
                array.remove(mtfFvgBullishFlags, i)
            else
                box.set_border_color(mtfStoredBox, fvgBorderColor)
                if extendFvgs
                    box.set_right(mtfStoredBox, time)
                if not na(mtfStoredLine)
                    if showFvgMidline
                        if extendFvgs
                            line.set_x2(mtfStoredLine, time)
                    else
                        line.delete(mtfStoredLine)
                        array.set(mtfFvgMidlines, i, na)

//------------------------------------------------------------------------------
// Session high/low tracking
//------------------------------------------------------------------------------
inAsiaSession = not na(time(timeframe.period, asiaSession, "America/New_York"))
inLondonSession = not na(time(timeframe.period, londonSession, "America/New_York"))

var float asiaHigh = na
var float asiaLow = na
var int asiaStartBar = na
var line asiaHighLine = na
var line asiaLowLine = na
var label asiaHighLabel = na
var label asiaLowLabel = na

asiaSessionStarted = inAsiaSession and (barstate.isfirst or not inAsiaSession[1])
asiaSessionActive = inAsiaSession and showAsiaSession
asiaSessionVisible = showAsiaSession

if asiaSessionStarted
    asiaHigh := high
    asiaLow := low
    asiaStartBar := bar_index
    if asiaSessionActive
        if not na(asiaHighLine)
            line.delete(asiaHighLine)
        if not na(asiaLowLine)
            line.delete(asiaLowLine)
        if not na(asiaHighLabel)
            label.delete(asiaHighLabel)
        if not na(asiaLowLabel)
            label.delete(asiaLowLabel)
        asiaHighLine := line.new(asiaStartBar, asiaHigh, bar_index, asiaHigh, extend=extend.right, color=asiaColor, width=1)
        asiaLowLine := line.new(asiaStartBar, asiaLow, bar_index, asiaLow, extend=extend.right, color=asiaColor, width=1)
        asiaHighLabel := label.new(bar_index, asiaHigh, "Asia High", style=label.style_label_left, color=asiaColor, textcolor=color.white, size=size.small)
        asiaLowLabel := label.new(bar_index, asiaLow, "Asia Low", style=label.style_label_left, color=asiaColor, textcolor=color.white, size=size.small)
else if inAsiaSession
    asiaHigh := math.max(nz(asiaHigh, high), high)
    asiaLow := math.min(nz(asiaLow, low), low)

if asiaSessionActive and not na(asiaHighLine) and not na(asiaLowLine)
    line.set_xy1(asiaHighLine, asiaStartBar, asiaHigh)
    line.set_xy2(asiaHighLine, bar_index, asiaHigh)
    line.set_xy1(asiaLowLine, asiaStartBar, asiaLow)
    line.set_xy2(asiaLowLine, bar_index, asiaLow)

if asiaSessionVisible and not na(asiaHighLabel) and not na(asiaLowLabel)
    label.set_xy(asiaHighLabel, bar_index, asiaHigh)
    label.set_xy(asiaLowLabel, bar_index, asiaLow)

var float londonHigh = na
var float londonLow = na
var int londonStartBar = na
var line londonHighLine = na
var line londonLowLine = na
var label londonHighLabel = na
var label londonLowLabel = na

londonSessionStarted = inLondonSession and (barstate.isfirst or not inLondonSession[1])
londonSessionActive = inLondonSession and showLondonSession
londonSessionVisible = showLondonSession

if londonSessionStarted
    londonHigh := high
    londonLow := low
    londonStartBar := bar_index
    if londonSessionActive
        if not na(londonHighLine)
            line.delete(londonHighLine)
        if not na(londonLowLine)
            line.delete(londonLowLine)
        if not na(londonHighLabel)
            label.delete(londonHighLabel)
        if not na(londonLowLabel)
            label.delete(londonLowLabel)
        londonHighLine := line.new(londonStartBar, londonHigh, bar_index, londonHigh, extend=extend.right, color=londonColor, width=1)
        londonLowLine := line.new(londonStartBar, londonLow, bar_index, londonLow, extend=extend.right, color=londonColor, width=1)
        londonHighLabel := label.new(bar_index, londonHigh, "London High", style=label.style_label_left, color=londonColor, textcolor=color.white, size=size.small)
        londonLowLabel := label.new(bar_index, londonLow, "London Low", style=label.style_label_left, color=londonColor, textcolor=color.white, size=size.small)
else if inLondonSession
    londonHigh := math.max(nz(londonHigh, high), high)
    londonLow := math.min(nz(londonLow, low), low)

if londonSessionActive and not na(londonHighLine) and not na(londonLowLine)
    line.set_xy1(londonHighLine, londonStartBar, londonHigh)
    line.set_xy2(londonHighLine, bar_index, londonHigh)
    line.set_xy1(londonLowLine, londonStartBar, londonLow)
    line.set_xy2(londonLowLine, bar_index, londonLow)

if londonSessionVisible and not na(londonHighLabel) and not na(londonLowLabel)
    label.set_xy(londonHighLabel, bar_index, londonHigh)
    label.set_xy(londonLowLabel, bar_index, londonLow)
