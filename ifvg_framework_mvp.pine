//@version=6
indicator("MS iFVG Framework [MVP]", overlay=true, max_boxes_count=200, max_lines_count=500, max_labels_count=500, max_bars_back=1000, behind_chart=false)

//------------------------------------------------------------------------------
// Inputs
//------------------------------------------------------------------------------
groupGeneral = "General"
detectionMode = input.string("Normal", "ATR strictness", options=["Sensitive", "Normal", "Strict"], group=groupGeneral)
swingLen      = input.int(5, "Swing length", minval=2, maxval=50, group=groupGeneral)
sweepWindow   = input.int(30, "Sweep validity window", minval=3, maxval=200, group=groupGeneral)
invertWindow  = input.int(15, "Inversion window after FVG", minval=3, maxval=100, group=groupGeneral)
extendBars    = input.int(80, "Extend IFVG/limit lines", minval=10, maxval=500, group=groupGeneral)
requireBody   = input.bool(true, "Require full candle body through gap", group=groupGeneral)
onlyConfirmed = input.bool(true, "Confirm on bar close only", group=groupGeneral)

showBull      = input.bool(true, "Show bullish IFVG", group=groupGeneral)
showBear      = input.bool(true, "Show bearish IFVG", group=groupGeneral)

// FVG settings
groupFvg      = "FVG / IFVG"
showFvgBoxes  = input.bool(true, "Show candidate FVG boxes", group=groupFvg)
showIfvgLine  = input.bool(true, "Show IFVG line", group=groupFvg)
showLimits    = input.bool(true, "Show BE / SL visual aids", group=groupFvg)
minTicks      = input.int(1, "Minimum gap ticks", minval=0, maxval=100, group=groupFvg)

bullColor     = input.color(color.rgb(38, 110, 255), "Bullish IFVG color", group=groupFvg)
bearColor     = input.color(color.rgb(255, 132, 0), "Bearish IFVG color", group=groupFvg)
fvgBullBg     = input.color(color.new(color.rgb(38, 110, 255), 92), "Bullish candidate box", group=groupFvg)
fvgBearBg     = input.color(color.new(color.rgb(255, 132, 0), 92), "Bearish candidate box", group=groupFvg)

// Sessions
groupSess     = "Liquidity / Sessions"
showSessions  = input.bool(true, "Show Asia/London highs and lows", group=groupSess)
showDataWick  = input.bool(true, "Show 08:30 NY data wick", group=groupSess)
nyTz          = input.string("America/New_York", "Session timezone", group=groupSess)
asiaSession   = input.session("2000-0000", "Asia session", group=groupSess)
londonSession = input.session("0200-0500", "London session", group=groupSess)

// Panel
groupPanel    = "Display"
displayMode   = input.string("Clean", "Display Mode", options=["Clean", "Standard", "Full Study"], group=groupPanel)
showPanel     = input.bool(true, "Show checklist panel", group=groupPanel)
panelPos      = input.string("Bottom Right", "Panel position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"], group=groupPanel)

// Alerts
groupAlerts   = "Alerts"
enableAlerts  = input.bool(true, "Enable alert() calls", group=groupAlerts)
msgBullIfvg   = input.string("Bullish IFVG confirmed on {{ticker}} {{interval}}", "Bullish IFVG message", group=groupAlerts)
msgBearIfvg   = input.string("Bearish IFVG confirmed on {{ticker}} {{interval}}", "Bearish IFVG message", group=groupAlerts)
msgSweepHigh  = input.string("Buy-side liquidity swept on {{ticker}} {{interval}}", "BSL sweep message", group=groupAlerts)
msgSweepLow   = input.string("Sell-side liquidity swept on {{ticker}} {{interval}}", "SSL sweep message", group=groupAlerts)

//------------------------------------------------------------------------------
// Helpers
//------------------------------------------------------------------------------
atr = ta.atr(14)
atrMult = switch detectionMode
    "Sensitive" => 0.02
    "Normal"    => 0.05
    => 0.10

isCleanMode = displayMode == "Clean"
isStandardMode = displayMode == "Standard"
isFullStudyMode = displayMode == "Full Study"
maxVisibleSetups = isCleanMode ? 1 : isStandardMode ? 3 : 20
maxVisibleLimitSetups = isFullStudyMode ? maxVisibleSetups : 1
showCandidateBoxes = showFvgBoxes and not isCleanMode
showLiquidityLabels = isFullStudyMode
showDataWickLabels = isFullStudyMode
showDataWickVisual = showDataWick and not isCleanMode

themeGrey = color.rgb(120, 128, 140)
beColor = color.rgb(255, 132, 0)
slColor = color.rgb(135, 140, 150)

minGap = math.max(syminfo.mintick * minTicks, atr * atrMult)
confirmedOk = not onlyConfirmed or barstate.isconfirmed

bodyTop(srcOpen, srcClose) => math.max(srcOpen, srcClose)
bodyBot(srcOpen, srcClose) => math.min(srcOpen, srcClose)

f_panel_position(pos) =>
    switch pos
        "Top Right"    => position.top_right
        "Top Left"     => position.top_left
        "Bottom Left"  => position.bottom_left
        => position.bottom_right

f_tick(ok) => ok ? "✓" : "×"
f_tick_color(ok) => ok ? color.rgb(0, 200, 120) : color.rgb(240, 70, 70)

var line[] activeIfvgLineArr = array.new_line()
var line[] activeBeLineArr = array.new_line()
var line[] activeSlLineArr = array.new_line()
var box[] activeIfvgBoxArr = array.new_box()
var label[] activeLabelArr = array.new_label()
var label[] activeBeLabelArr = array.new_label()
var label[] activeSlLabelArr = array.new_label()

f_delete_line(line ln) =>
    if not na(ln)
        line.delete(ln)

f_delete_box(box bx) =>
    if not na(bx)
        box.delete(bx)

f_delete_label(label lb) =>
    if not na(lb)
        label.delete(lb)

f_trim_lines(array<line> lines, int limit) =>
    while array.size(lines) > limit
        f_delete_line(array.shift(lines))

f_trim_boxes(array<box> boxes, int limit) =>
    while array.size(boxes) > limit
        f_delete_box(array.shift(boxes))

f_trim_labels(array<label> labels, int limit) =>
    while array.size(labels) > limit
        f_delete_label(array.shift(labels))

f_trim_active_visuals() =>
    f_trim_lines(activeIfvgLineArr, maxVisibleSetups)
    f_trim_boxes(activeIfvgBoxArr, maxVisibleSetups)
    f_trim_lines(activeBeLineArr, maxVisibleLimitSetups)
    f_trim_lines(activeSlLineArr, maxVisibleLimitSetups)
    f_trim_labels(activeLabelArr, maxVisibleSetups)
    f_trim_labels(activeBeLabelArr, maxVisibleLimitSetups)
    f_trim_labels(activeSlLabelArr, maxVisibleLimitSetups)

//------------------------------------------------------------------------------
// Liquidity pivots and sweeps. Pivots are confirmed after swingLen bars.
//------------------------------------------------------------------------------
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow(low, swingLen, swingLen)

var float lastSwingHigh = na
var float lastSwingLow  = na
var int   lastSwingHighBar = na
var int   lastSwingLowBar  = na

if not na(ph)
    lastSwingHigh := ph
    lastSwingHighBar := bar_index - swingLen

if not na(pl)
    lastSwingLow := pl
    lastSwingLowBar := bar_index - swingLen

sweepHigh = confirmedOk and not na(lastSwingHigh) and high > lastSwingHigh and close < lastSwingHigh
sweepLow  = confirmedOk and not na(lastSwingLow) and low < lastSwingLow and close > lastSwingLow

var int   lastBSLBar = na
var int   lastSSLBar = na
var float lastBSLPrice = na
var float lastSSLPrice = na

if sweepHigh
    lastBSLBar := bar_index
    lastBSLPrice := high
    if showLiquidityLabels
        label.new(bar_index, high, "BSL", xloc=xloc.bar_index, style=label.style_label_down, textcolor=color.white, color=color.new(bearColor, 10), size=size.tiny)

if sweepLow
    lastSSLBar := bar_index
    lastSSLPrice := low
    if showLiquidityLabels
        label.new(bar_index, low, "SSL", xloc=xloc.bar_index, style=label.style_label_up, textcolor=color.white, color=color.new(bullColor, 10), size=size.tiny)

recentBSL = not na(lastBSLBar) and bar_index - lastBSLBar <= sweepWindow
recentSSL = not na(lastSSLBar) and bar_index - lastSSLBar <= sweepWindow

//------------------------------------------------------------------------------
// Body-based FVG detection. Direction: +1 bullish FVG, -1 bearish FVG.
// Bullish FVG: current candle body is above the body from two candles back.
// Bearish FVG: current candle body is below the body from two candles back.
//------------------------------------------------------------------------------
bTop0 = bodyTop(open, close)
bBot0 = bodyBot(open, close)
bTop2 = bodyTop(open[2], close[2])
bBot2 = bodyBot(open[2], close[2])

bullFvg = confirmedOk and bBot0 > bTop2 and (bBot0 - bTop2) >= minGap
bearFvg = confirmedOk and bTop0 < bBot2 and (bBot2 - bTop0) >= minGap

var float[] fvgTopArr = array.new_float()
var float[] fvgBotArr = array.new_float()
var int[]   fvgDirArr = array.new_int()
var int[]   fvgBarArr = array.new_int()
var box[]   fvgBoxArr = array.new_box()
var box[]   archivedFvgBoxArr = array.new_box()

if bullFvg or bearFvg
    float top = bullFvg ? bBot0 : bBot2
    float bot = bullFvg ? bTop2 : bTop0
    int dir = bullFvg ? 1 : -1
    color bg = color.new(dir == 1 ? fvgBullBg : fvgBearBg, isFullStudyMode ? 90 : 95)
    box bx = na
    if showCandidateBoxes
        bx := box.new(bar_index - 2, top, bar_index, bot, xloc=xloc.bar_index, bgcolor=bg, border_color=color.new(dir == 1 ? bullColor : bearColor, 90))
    array.push(fvgTopArr, top)
    array.push(fvgBotArr, bot)
    array.push(fvgDirArr, dir)
    array.push(fvgBarArr, bar_index)
    array.push(fvgBoxArr, bx)

//------------------------------------------------------------------------------
// Inversion validation and lifecycle
//------------------------------------------------------------------------------
var bool bullIfvgNow = false
var bool bearIfvgNow = false
var float lastIfvgPrice = na
var int lastIfvgDir = 0
var bool lastHasTarget = false
var bool lastMomentum = false

bullIfvgNow := false
bearIfvgNow := false
lastMomentum := false

fvgCount = array.size(fvgTopArr)
if fvgCount > 0
    for j = 0 to fvgCount - 1
        int i = fvgCount - 1 - j
        float top = array.get(fvgTopArr, i)
        float bot = array.get(fvgBotArr, i)
        int dir = array.get(fvgDirArr, i)
        int created = array.get(fvgBarArr, i)
        box bx = array.get(fvgBoxArr, i)
        int age = bar_index - created

        if showCandidateBoxes and not na(bx)
            box.set_right(bx, bar_index)

        bool expired = age > invertWindow
        bool bodyThroughUp = requireBody ? bBot0 > top : close > top
        bool bodyThroughDn = requireBody ? bTop0 < bot : close < bot

        // Bearish FVG inverts upward after sell-side sweep -> bullish IFVG.
        bool bullishInversion = showBull and dir == -1 and recentSSL and bodyThroughUp and confirmedOk
        // Bullish FVG inverts downward after buy-side sweep -> bearish IFVG.
        bool bearishInversion = showBear and dir == 1 and recentBSL and bodyThroughDn and confirmedOk

        if bullishInversion or bearishInversion
            int invDir = bullishInversion ? 1 : -1
            float ifvgPrice = close
            color c = invDir == 1 ? bullColor : bearColor
            string txt = invDir == 1 ? "DD+" : "DD-"
            line ddLine = na
            line slLine = na
            line beLine = na
            label ddLabel = na
            label slLabel = na
            label beLabel = na

            if showIfvgLine
                ddLine := line.new(bar_index, ifvgPrice, bar_index + extendBars, ifvgPrice, xloc=xloc.bar_index, color=c, width=2)
                ddLabel := label.new(bar_index + extendBars, ifvgPrice, txt, xloc=xloc.bar_index, style=label.style_label_left, textcolor=color.white, color=color.new(c, 12), size=size.tiny)

            // Educational limit aids only: SL at sweep extreme; BE shown as 1R from entry.
            if showLimits
                float sl = invDir == 1 ? lastSSLPrice : lastBSLPrice
                float risk = math.abs(ifvgPrice - sl)
                float be = invDir == 1 ? ifvgPrice + risk : ifvgPrice - risk
                if not na(sl) and risk > 0
                    slLine := line.new(bar_index, sl, bar_index + extendBars, sl, xloc=xloc.bar_index, color=color.new(slColor, 0), width=1, style=line.style_dotted)
                    slLabel := label.new(bar_index + extendBars, sl, "SL", xloc=xloc.bar_index, style=label.style_label_left, textcolor=color.white, color=color.new(slColor, 15), size=size.tiny)
                    beLine := line.new(bar_index, be, bar_index + extendBars, be, xloc=xloc.bar_index, color=color.new(beColor, 10), width=1, style=line.style_dashed)
                    beLabel := label.new(bar_index + extendBars, be, "BE", xloc=xloc.bar_index, style=label.style_label_left, textcolor=color.white, color=color.new(beColor, 15), size=size.tiny)

            if not na(bx)
                box.set_bgcolor(bx, color.new(c, isCleanMode ? 100 : 88))
                box.set_border_color(bx, color.new(c, isCleanMode ? 100 : 45))

            array.push(activeIfvgLineArr, ddLine)
            array.push(activeBeLineArr, beLine)
            array.push(activeSlLineArr, slLine)
            array.push(activeIfvgBoxArr, bx)
            array.push(activeLabelArr, ddLabel)
            array.push(activeSlLabelArr, slLabel)
            array.push(activeBeLabelArr, beLabel)
            f_trim_active_visuals()

            bullIfvgNow := bullishInversion
            bearIfvgNow := bearishInversion
            lastIfvgPrice := ifvgPrice
            lastIfvgDir := invDir
            lastMomentum := math.abs(close - open) >= atr * 0.35
            lastHasTarget := invDir == 1 ? not na(lastSwingHigh) and lastSwingHigh > close : not na(lastSwingLow) and lastSwingLow < close

            // Remove candidate after it becomes active IFVG.
            array.remove(fvgTopArr, i)
            array.remove(fvgBotArr, i)
            array.remove(fvgDirArr, i)
            array.remove(fvgBarArr, i)
            array.remove(fvgBoxArr, i)
        else if expired
            if not na(bx)
                if isFullStudyMode
                    array.push(archivedFvgBoxArr, bx)
                    f_trim_boxes(archivedFvgBoxArr, 120)
                else
                    box.delete(bx)
            array.remove(fvgTopArr, i)
            array.remove(fvgBotArr, i)
            array.remove(fvgDirArr, i)
            array.remove(fvgBarArr, i)
            array.remove(fvgBoxArr, i)

//------------------------------------------------------------------------------
// Sessions and 08:30 NY data wick
//------------------------------------------------------------------------------
inAsia = not na(time(timeframe.period, asiaSession, nyTz))
inLondon = not na(time(timeframe.period, londonSession, nyTz))

newAsia = inAsia and not inAsia[1]
newLondon = inLondon and not inLondon[1]

var float asiaHi = na
var float asiaLo = na
var float londonHi = na
var float londonLo = na
var line asiaHiLine = na
var line asiaLoLine = na
var line londonHiLine = na
var line londonLoLine = na

if showSessions
    if newAsia
        if not isFullStudyMode
            f_delete_line(asiaHiLine)
            f_delete_line(asiaLoLine)
        asiaHi := high
        asiaLo := low
        asiaHiLine := line.new(bar_index, asiaHi, bar_index + 1, asiaHi, xloc=xloc.bar_index, color=color.new(themeGrey, isCleanMode ? 70 : 55), style=line.style_dotted)
        asiaLoLine := line.new(bar_index, asiaLo, bar_index + 1, asiaLo, xloc=xloc.bar_index, color=color.new(themeGrey, isCleanMode ? 70 : 55), style=line.style_dotted)
    if inAsia
        asiaHi := math.max(nz(asiaHi, high), high)
        asiaLo := math.min(nz(asiaLo, low), low)
        if not na(asiaHiLine)
            line.set_xy2(asiaHiLine, bar_index + extendBars, asiaHi)
            line.set_y1(asiaHiLine, asiaHi)
        if not na(asiaLoLine)
            line.set_xy2(asiaLoLine, bar_index + extendBars, asiaLo)
            line.set_y1(asiaLoLine, asiaLo)

    if newLondon
        if not isFullStudyMode
            f_delete_line(londonHiLine)
            f_delete_line(londonLoLine)
        londonHi := high
        londonLo := low
        londonHiLine := line.new(bar_index, londonHi, bar_index + 1, londonHi, xloc=xloc.bar_index, color=color.new(themeGrey, isCleanMode ? 60 : 40), style=line.style_dashed)
        londonLoLine := line.new(bar_index, londonLo, bar_index + 1, londonLo, xloc=xloc.bar_index, color=color.new(themeGrey, isCleanMode ? 60 : 40), style=line.style_dashed)
    if inLondon
        londonHi := math.max(nz(londonHi, high), high)
        londonLo := math.min(nz(londonLo, low), low)
        if not na(londonHiLine)
            line.set_xy2(londonHiLine, bar_index + extendBars, londonHi)
            line.set_y1(londonHiLine, londonHi)
        if not na(londonLoLine)
            line.set_xy2(londonLoLine, bar_index + extendBars, londonLo)
            line.set_y1(londonLoLine, londonLo)

nyHour = hour(time, nyTz)
nyMin = minute(time, nyTz)
isDataBar = confirmedOk and showDataWickVisual and nyHour == 8 and nyMin == 30
if isDataBar
    line.new(bar_index, high, bar_index + extendBars, high, xloc=xloc.bar_index, color=color.new(themeGrey, 35), style=line.style_dotted)
    line.new(bar_index, low, bar_index + extendBars, low, xloc=xloc.bar_index, color=color.new(themeGrey, 35), style=line.style_dotted)
    if showDataWickLabels
        label.new(bar_index, high, "DATA.H", xloc=xloc.bar_index, style=label.style_label_down, textcolor=color.white, color=color.new(themeGrey, 15), size=size.tiny)
        label.new(bar_index, low, "DATA.L", xloc=xloc.bar_index, style=label.style_label_up, textcolor=color.white, color=color.new(themeGrey, 15), size=size.tiny)

//------------------------------------------------------------------------------
// Checklist and grade
//------------------------------------------------------------------------------
liquidityOk = recentSSL or recentBSL
fvgOk = bullFvg or bearFvg or array.size(fvgTopArr) > 0
ifvgOk = bullIfvgNow or bearIfvgNow
momentumOk = lastMomentum or math.abs(close - open) >= atr * 0.35
clearTargetsOk = lastHasTarget
htfOk = false  // Reserved for Phase 2: HTF PD Array delivery.
smtOk = false  // Reserved for Phase 3: SMT divergence module.

score = (liquidityOk ? 1 : 0) + (fvgOk ? 1 : 0) + (momentumOk ? 1 : 0) + (ifvgOk ? 2 : 0) + (clearTargetsOk ? 1 : 0) + (htfOk ? 1 : 0) + (smtOk ? 1 : 0)
grade = score >= 7 ? "A+" : score >= 6 ? "A" : score >= 5 ? "B+" : score >= 4 ? "B" : "C"

tablePos = f_panel_position(panelPos)
var table t = table.new(tablePos, 2, 8, bgcolor=color.new(themeGrey, 18), border_width=1)

if showPanel and barstate.islast
    table.cell(t, 0, 0, "Setup Grade", text_color=color.white, bgcolor=color.new(themeGrey, 15), text_size=size.tiny)
    table.cell(t, 1, 0, grade, text_color=grade == "A+" or grade == "A" ? beColor : color.white, bgcolor=color.new(themeGrey, 15), text_size=size.tiny)

    table.cell(t, 0, 1, "Checklist", text_color=color.white, bgcolor=color.new(themeGrey, 35), text_size=size.tiny)
    table.cell(t, 1, 1, "Status", text_color=color.white, bgcolor=color.new(themeGrey, 35), text_size=size.tiny)

    table.cell(t, 0, 2, "Liquidity Sweep", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, f_tick(liquidityOk), text_color=f_tick_color(liquidityOk), text_size=size.small)

    table.cell(t, 0, 3, "HTF PDA Delivery", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, f_tick(htfOk), text_color=f_tick_color(htfOk), text_size=size.small)

    table.cell(t, 0, 4, "Momentum", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, f_tick(momentumOk), text_color=f_tick_color(momentumOk), text_size=size.small)

    table.cell(t, 0, 5, "IFVG", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, f_tick(ifvgOk), text_color=f_tick_color(ifvgOk), text_size=size.small)

    table.cell(t, 0, 6, "Clear Targets", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 6, f_tick(clearTargetsOk), text_color=f_tick_color(clearTargetsOk), text_size=size.small)

    table.cell(t, 0, 7, "SMT / MF", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 7, f_tick(smtOk), text_color=f_tick_color(smtOk), text_size=size.small)

if not showPanel and barstate.islast
    table.clear(t, 0, 0, 1, 7)

//------------------------------------------------------------------------------
// Alerts. Users still create the alert from TradingView's Create Alert dialog.
//------------------------------------------------------------------------------
alertcondition(bullIfvgNow, "Bullish IFVG confirmed", "Bullish IFVG confirmed")
alertcondition(bearIfvgNow, "Bearish IFVG confirmed", "Bearish IFVG confirmed")
alertcondition(sweepHigh, "Buy-side liquidity swept", "Buy-side liquidity swept")
alertcondition(sweepLow, "Sell-side liquidity swept", "Sell-side liquidity swept")

if enableAlerts and barstate.isconfirmed
    if bullIfvgNow
        alert(msgBullIfvg, alert.freq_once_per_bar_close)
    if bearIfvgNow
        alert(msgBearIfvg, alert.freq_once_per_bar_close)
    if sweepHigh
        alert(msgSweepHigh, alert.freq_once_per_bar_close)
    if sweepLow
        alert(msgSweepLow, alert.freq_once_per_bar_close)
